{
	"name": "lzt-sdk",
	"version": "1.0.0",
	"description": "Type-safe SDK for Lolzteam Market and Forum APIs",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./market": {
			"types": "./dist/market/index.d.ts",
			"import": "./dist/market/index.js",
			"default": "./dist/market/index.js"
		},
		"./market/*": {
			"types": "./dist/market/*.d.ts",
			"import": "./dist/market/*.js"
		},
		"./market/*.js": {
			"types": "./dist/market/*.d.ts",
			"import": "./dist/market/*.js"
		},
		"./forum": {
			"types": "./dist/forum/index.d.ts",
			"import": "./dist/forum/index.js",
			"default": "./dist/forum/index.js"
		},
		"./forum/*": {
			"types": "./dist/forum/*.d.ts",
			"import": "./dist/forum/*.js"
		},
		"./forum/*.js": {
			"types": "./dist/forum/*.d.ts",
			"import": "./dist/forum/*.js"
		},
		"./errors": {
			"types": "./dist/core/errors/index.d.ts",
			"import": "./dist/core/errors/index.js",
			"default": "./dist/core/errors/index.js"
		},
		"./errors/*": {
			"types": "./dist/core/errors/*.d.ts",
			"import": "./dist/core/errors/*.js"
		},
		"./errors/*.js": {
			"types": "./dist/core/errors/*.d.ts",
			"import": "./dist/core/errors/*.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js",
			"default": "./dist/types/index.js"
		},
		"./types/*": {
			"types": "./dist/types/*.d.ts",
			"import": "./dist/types/*.js"
		},
		"./types/*.js": {
			"types": "./dist/types/*.d.ts",
			"import": "./dist/types/*.js"
		},
		"./generated": {
			"types": "./dist/core/generated/index.d.ts",
			"import": "./dist/core/generated/index.js",
			"default": "./dist/core/generated/index.js"
		},
		"./generated/*": {
			"types": "./dist/core/generated/*.d.ts",
			"import": "./dist/core/generated/*.js"
		},
		"./generated/*.js": {
			"types": "./dist/core/generated/*.d.ts",
			"import": "./dist/core/generated/*.js"
		},
		"./http": {
			"types": "./dist/core/http/index.d.ts",
			"import": "./dist/core/http/index.js",
			"default": "./dist/core/http/index.js"
		},
		"./http/*": {
			"types": "./dist/core/http/*.d.ts",
			"import": "./dist/core/http/*.js"
		},
		"./http/*.js": {
			"types": "./dist/core/http/*.d.ts",
			"import": "./dist/core/http/*.js"
		},
		"./dist/market": "./dist/market/index.js",
		"./dist/forum": "./dist/forum/index.js",
		"./dist/errors": "./dist/core/errors/index.js",
		"./dist/types": "./dist/types/index.js",
		"./dist/generated": "./dist/core/generated/index.js",
		"./dist/http": "./dist/core/http/index.js",
		"./dist/*": "./dist/*",
		"./package.json": "./package.json"
	},
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist',{ recursive:true, force:true })\"",
		"build": "npm run clean && tsc",
		"build:tsdown": "npm run clean && tsdown",
		"dev": "tsc --watch",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:local": "tsx examples/example.ts",
		"test:built": "node examples/example.js",
		"lint": "eslint src/**/*.ts",
		"format": "prettier --write \"src/**/*.ts\"",
		"typecheck": "tsc --noEmit",
		"generate:types": "node scripts/generate-openapi-types.mjs",
		"generate:api": "node scripts/generate-api-methods.mjs",
		"generate": "npm run generate:types && npm run generate:api",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"dotenv": "^17.4.1",
		"openapi-fetch": "^0.17.0",
		"pino": "^10.3.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"tsdown": "^0.21.7",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	}
}
